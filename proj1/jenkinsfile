pipeline{
    agent any

    environment{
        FRONTEND_IMAGE= "mern-frontend:jenkins"
        BACKEND_IMAGE= "mern-backend:jenkins"
        PORT= "3001"
        MONGO_URI= "mongodb://mongo:27017/taskdb"
    }

    stages{
        stage("Checkout"){
            steps{
                git url: 'https://github.com/junaid-rizwan/dev-ops.git',branch: 'master/main'
            }
        }
        stage("prep .env"){
            steps{
                sh 'cp ./server/.env.example ./server/.env'
                sh 'cp ./client/.env.example ./client/.env'
            }
        }
        stage("Build"){
            steps{
                
                sh 'docker build -t $FRONTEND_IMAGE ./client'
                sh 'docker build -t $BACKEND_IMAGE ./server'
            }
        }
        stage("Push"){
            steps{
                sh 'docker push $FRONTEND_IMAGE'
                sh 'docker push $BACKEND_IMAGE'
            }
        }
        stage("Deploy"){
            steps{
                sh 'docker-compose -f docker-compose.yml up -d'
            }
        }
       
        
    }

}